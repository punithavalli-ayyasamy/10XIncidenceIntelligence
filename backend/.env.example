# Copy to backend/.env and fill in real values.
# Never commit .env — it is gitignored.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional: set false to fail hard when Gemini is unavailable
ALLOW_HEURISTIC_LLM_FALLBACK=true

# Observability (Cloud Logging via stdout JSON + Cloud Trace via OpenTelemetry)
SERVICE_NAME=tenx-incident-api
LOG_LEVEL=INFO
# Auto-enable on Cloud Run (K_SERVICE). Force locally with:
ENABLE_CLOUD_LOGGING=false
ENABLE_CLOUD_TRACE=false
CLOUD_OBSERVABILITY_AUTO=true
# Local span debug (prints to console):
TRACE_CONSOLE_EXPORT=false
